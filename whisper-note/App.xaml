<Application x:Class="WhisperNote.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WhisperNote.ViewModels"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/ToolTipStyle.xaml"/>
                <ResourceDictionary Source="Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="Styles/ComboBoxStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <vm:StatusKindToBrushConverter x:Key="StatusKindToBrushConverter"/>
            <vm:ButtonBackgroundKindToBrushConverter x:Key="ButtonBackgroundKindToBrushConverter"/>
            <vm:ServerStatusKindToBrushConverter x:Key="ServerStatusKindToBrushConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
