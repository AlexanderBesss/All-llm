<Window x:Class="WhisperNote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhisperNote"
        Width="380" Height="260"
        Topmost="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#1A1A1A" CornerRadius="12" Padding="20" ClipToBounds="True"
            Opacity="{Binding WindowOpacity}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="WhisperNote" FontSize="16" FontWeight="SemiBold"
                           Foreground="#E0E0E0" VerticalAlignment="Center"/>
                <TextBlock Width="8" Height="8" Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Text="●" FontSize="8"
                           Foreground="{Binding ServerManager.Status.Kind, Converter={StaticResource ServerStatusKindToBrushConverter}}"/>
                <TextBlock Text="{Binding ServerManager.Status.Message}" FontSize="11"
                           Foreground="{Binding ServerManager.Status.Kind, Converter={StaticResource ServerStatusKindToBrushConverter}}"
                           VerticalAlignment="Center" Margin="6,0,0,0"
                           MaxWidth="80" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding ActiveModuleName}"
                           FontSize="10" Foreground="#999"
                           VerticalAlignment="Center" Margin="8,0,0,0"
                           MaxWidth="150" TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding ActiveModuleName}"/>
            </StackPanel>

            <!-- Main recording area -->
             <Grid Grid.Row="1">
                 <Border Background="#222" CornerRadius="16" Padding="20,12,20,12" ClipToBounds="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                       <!-- Record button (click fallback) -->
                        <Button Grid.Column="0"
                                Style="{StaticResource CircleButton}"
                                Width="64" Height="64"
                                Background="{Binding RecordingManager.MainButtonBackgroundKind, Converter={StaticResource ButtonBackgroundKindToBrushConverter}}"
                                BorderBrush="#555" BorderThickness="2"
                                Command="{Binding RecordCommand}"
                                Cursor="Hand">
                            <Ellipse Width="18" Height="18" Fill="#E0E0E0"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                   <!-- Status text -->
                        <Grid Grid.Column="1" Margin="16,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollViewer x:Name="StatusScrollViewer" Grid.Row="0"
                                          VerticalScrollBarVisibility="Hidden"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Focusable="True" FocusManager.IsFocusScope="True"
                                          Padding="4,0,4,0">
                                <TextBlock Text="{Binding RecordingManager.StatusText}"
                                           FontSize="14" FontWeight="Medium"
                                           Foreground="{Binding RecordingManager.StatusTextKind, Converter={StaticResource StatusKindToBrushConverter}}"
                                           TextWrapping="Wrap"/>
                            </ScrollViewer>

                            <TextBlock Grid.Row="1" Text="{Binding RecordingManager.InfoText}"
                                       FontSize="11" Foreground="#666"
                                       Margin="0,8,0,0" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="2" Text="{Binding HotkeyName}"
                                       FontSize="9" Foreground="#555"
                                       Margin="0,2,0,0" Opacity="0.7"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Bottom controls -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0"
                        HorizontalAlignment="Center">
                <Button Style="{StaticResource IconButton}"
                        Command="{Binding ServerCommand}" Margin="0,0,8,0"
                        ToolTip="Toggle Server">
                    <TextBlock Text="⏻" FontSize="16"
                               Foreground="{Binding ServerManager.Status.Kind, Converter={StaticResource ServerStatusKindToBrushConverter}}"/>
                </Button>
                <ToggleButton IsChecked="{Binding AutoOffloadVram, Mode=TwoWay}"
                              Style="{StaticResource IconToggleButton}"
                              Margin="0,0,8,0"
                              ToolTip="Stop server after each request (free VRAM)">
                    <TextBlock Text="🧠" FontSize="14"/>
                </ToggleButton>
                <ToggleButton IsChecked="{Binding ThinkingEnabled, Mode=TwoWay}"
                              Style="{StaticResource IconToggleButton}"
                              Margin="0,0,8,0"
                              ToolTip="Thinking mode (restart server to apply)">
                    <TextBlock Text="💡" FontSize="14"/>
                </ToggleButton>
                <ToggleButton IsChecked="{Binding StartupEnabled, Mode=TwoWay}"
                              Style="{StaticResource IconToggleButton}"
                              Margin="0,0,8,0"
                              ToolTip="Run on Windows startup">
                    <TextBlock Text="⚡" FontSize="16"/>
                </ToggleButton>
                <Button Style="{StaticResource IconButton}"
                        Command="{Binding CloseCommand}"
                        ToolTip="Close">
                    <TextBlock Text="✕" FontSize="14"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
