<Window x:Class="WhisperNote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhisperNote"
        Width="380" Height="260"
        Topmost="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#1A1A1A" CornerRadius="12" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="WhisperNote" FontSize="16" FontWeight="SemiBold"
                           Foreground="#E0E0E0" VerticalAlignment="Center"/>
                <TextBlock Width="8" Height="8" Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Text="●" FontSize="8"
                           Foreground="{Binding ServerManager.ServerDotColor}"/>
                <TextBlock Text="{Binding ServerManager.ServerStatusMessage}" FontSize="11"
                           Foreground="{Binding ServerManager.ServerStatusTextColor}"
                           VerticalAlignment="Center" Margin="6,0,0,0"
                           MaxWidth="80" TextTrimming="CharacterEllipsis"/>
                <ComboBox ItemsSource="{Binding Providers}"
                          SelectedIndex="{Binding SelectedProviderIndex, Mode=TwoWay}"
                          DisplayMemberPath="Name"
                          Width="140" Margin="8,0,0,0"
                          Background="#2A2A2A" Foreground="#CCC" BorderBrush="#444"
                          FontSize="10" VerticalAlignment="Center" Padding="4,2">
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="#2A2A2A"/>
                            <Setter Property="Foreground" Value="#CCC"/>
                            <Setter Property="FontSize" Value="10"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="MinHeight" Value="20"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="#333" BorderThickness="0,0,0,1"
                                                Padding="4,2"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>
            </StackPanel>

            <!-- Main recording area -->
            <Grid Grid.Row="1">
                <Border Background="#222" CornerRadius="16" Padding="30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Record button -->
                        <Button Grid.Column="0"
                                Style="{StaticResource CircleButton}"
                                Width="64" Height="64"
                                Background="{Binding RecordingManager.MainButtonBackground}"
                                BorderBrush="#555" BorderThickness="2"
                                Command="{Binding RecordCommand}"
                                Cursor="Hand">
                            <Ellipse Width="18" Height="18" Fill="#E0E0E0"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- Status text -->
                        <StackPanel Grid.Column="1" Margin="16,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding RecordingManager.StatusText}"
                                       FontSize="14" FontWeight="Medium"
                                       Foreground="{Binding RecordingManager.StatusTextColor}"/>
                            <TextBlock Text="{Binding RecordingManager.InfoText}"
                                       FontSize="11" Foreground="#666"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Bottom controls -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0"
                        HorizontalAlignment="Center">
                <Button Style="{StaticResource IconButton}"
                        Command="{Binding ServerCommand}" Margin="0,0,8,0"
                        ToolTip="Toggle Server">
                    <TextBlock Text="⏻" FontSize="16"/>
                </Button>
                <Button Style="{StaticResource IconButton}"
                        Command="{Binding ClipboardCommand}" Margin="0,0,8,0"
                        ToolTip="Copy last transcription">
                    <TextBlock Text="📋" FontSize="14"/>
                </Button>
                <ToggleButton IsChecked="{Binding StartupEnabled, Mode=TwoWay}"
                              Style="{StaticResource IconToggleButton}"
                              Margin="0,0,8,0"
                              ToolTip="Run on Windows startup">
                    <TextBlock Text="⚡" FontSize="16"/>
                </ToggleButton>
                <Button Style="{StaticResource IconButton}"
                        Command="{Binding CloseCommand}"
                        ToolTip="Close">
                    <TextBlock Text="✕" FontSize="14"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
